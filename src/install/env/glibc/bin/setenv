#!/bin/bash
# shellcheck disable=SC2139

unset BASH_ENV
export BASH_ENV

# update_path_variable: Safely modify PATH-like environment variables
#
# PURPOSE:
#   Prevents duplicate entries in environment variables like PATH, LD_LIBRARY_PATH, 
#   MANPATH, etc. This ensures consistent behavior and avoids bloating path variables 
#   with redundant entries which could lead to:
#   - Slower path resolution
#   - Harder debugging of environment issues
#   - Unexpected behavior when the same path appears multiple times
#
# PARAMETERS:
#   $1 (var_name)       - The name of the environment variable to modify
#   $2 (folder_path)    - The directory path to add to the variable
#   $3 (append_to_path) - If non-empty, append to end; otherwise prepend to beginning
#
# USAGE EXAMPLES:
#   update_path_variable "PATH" "/opt/custom/bin" ""      # Prepend to PATH
#   update_path_variable "LD_LIBRARY_PATH" "/usr/local/lib" "append"  # Append to LD_LIBRARY_PATH
#
update_path_variable() {
    local var_name=$1
    local folder_path=$2
    local append_to_path=$3

    # Get the current value of the variable
    local var_value
    var_value=$(eval echo \$"${var_name}")

    # Check if the folder path is already in the variable value
    if [[ ":$var_value:" != *":$folder_path:"* ]]; then
        if [[ -z "${var_value}" ]]; then
            # If the variable is empty, set it directly
            var_value="${folder_path}"
        # Update the variable value
        elif [[ -n "${append_to_path}" ]]; then
            # Append the folder path to the end
            var_value="${var_value}:${folder_path}"
        else
            # Prepend the folder path to the beginning
            var_value="${folder_path}:${var_value}"
        fi
        eval export "${var_name}"="${var_value}"
    fi
}

tool_dir="$( cd "$( dirname "$(readlink -f "${BASH_SOURCE[0]}")" )" && pwd )"
tool_dir="$(dirname "${tool_dir}")"
export tool_dir
tool_root="${tool_dir}/root"
export tool_root
tool_current="${tool_dir}/current"
export tool_current
tools="$(dirname "${tool_dir}")"

# shellcheck disable=SC1091
source "${tools}/echos/echos"

# shellcheck disable=SC1091
source "${tools}/update_path_variables.sh"
if ! declare -f update_path_variable >/dev/null 2>&1; then
    fatal "No path var function present" 116
fi

if ! [ -d "${tool_dir}/current" ]; then
    ln -nfs ../current "${tool_dir}/current"
fi
if ! [ -d "${tool_dir}/root" ]; then
    ln -nfs ../root "${tool_dir}/root"
fi

export PERLLIB="${tool_dir}/root/usr/lib64/perl5/vendor_perl:${tool_dir}/root/usr/share/perl5/vendor_perl"


update_path_variable "PATH" "${tool_dir}/current/bin"
update_path_variable "PATH" "${tool_dir}/current/sbin"
update_path_variable "PATH" "${tool_dir}/current/libexec/getconf"
export LD_LIBRARY_PATH="${tool_current}/lib:${tool_root}/usr/lib64:${tool_root}/usr/lib:${tool_root}/lib64:${tool_root}/lib"
update_path_variable "MANPATH" "${tool_dir}/current/share/man"
alias man='BASH_ENV= "${tool_dir}/bin/manw.sh"'

export NEW_LIB_DIR="${tool_dir}/current/lib" # Verify this path!
export NEW_LDSO="${tool_dir}/sources/build/elf/ld-linux-x86-64.so.2"      # Verify this path!


#find ${PERLLIB}
#which git
#which git-add
#git version
#git ls-remote
#git add -p .
#export GIT_TRACE2=1

