#!/bin/bash

DIR="$( cd "$( dirname "$(readlink -f "${BASH_SOURCE[0]}")" )" && pwd )"
#echo "${DIR}"
# shellcheck source=/dev/null
source "${DIR}/../.env"
# shellcheck source=/dev/null
source "${DIR}/../echos/echos"
# shellcheck source=/dev/null
source "${DIR}/../bin/properties.sh"

# Check if ${DIR}/root/usr/bin is part of the $PATH. If not, add it at the end of the $PATH
bin_dir="${DIR}/root/usr/bin"
# Wrap PATH in colons for the check so that boundaries are properly detected,
# even if PATH does not end with a colon.
if [[ ":$PATH:" != *":${bin_dir}:"* ]]; then
    export PATH="${PATH}:${bin_dir}"
    info "Added '${bin_dir}' to PATH."
else
    ok "'${bin_dir}' is already in the PATH."
fi

# Check if exactly at least two parameter is provided
if [[ $# -lt 2 ]]; then
    fatal "Usage: install <tool_name> <version>" 1
fi

tool="$1"

# shellcheck disable=SC2034
properties_file="${DIR}/../cplx.properties"
# Resolve to canonical, normalized path
properties_file=$(readlink -f "$properties_file")
export properties_file
# Retrieve the list of valid services (comma-separated)
get_property services  # Example: "service1,service2,service3"
if [[ -z "$services" ]]; then
    fatal "No services found in the properties file '${properties_file}'" 1
fi

# Convert the comma-separated services into an array
IFS=',' read -r -a service_array <<< "$services"

# Flag to indicate if the tool is valid
valid=false

# Iterate through the services to check for a match
for service in "${service_array[@]}"; do
    if [[ "$service" == "$tool" ]]; then
        valid=true
        break
    fi
done

# If the tool is not valid, use fatal to exit with an error message
if [[ "$valid" == false ]]; then
    fatal "Invalid tool name: '${tool}'. Available tools are: ${services}" 1
fi

if [[ ! -e "${DIR}/${tool}/${tool}_install_functions.sh" ]]; then
    fatal "Tool '${tool}_install_functions.sh' script not found at '${DIR}/${tool}'" 2
else
    # shellcheck source=/dev/null
    source "${DIR}/${tool}/${tool}_install_functions.sh"
fi
rm -f "${DIR}/tool"
ln -nfs "${tool}" "${DIR}/tool"

# Define the sources directory
sources_dir="${DIR}/${tool}/sources"

# Remove any old log
prj="${DIR}/${tool}"
logs="${prj}/logs"
rm -f "${prj}/log" 2>/dev/null

# Enable nullglob to handle cases with no matching files
shopt -s nullglob

# Array of possible archive extensions
declare -a archive_extensions=("zip" "tar.gz" "tar.xz" "tar")

# Initialize an empty array to hold matching archives
matching_archives=()

version="$2"

# Iterate over each extension to find matching archives
for ext in "${archive_extensions[@]}"; do
    pattern="*${version}*.${ext}"

    # Use find to collect matching files and append to the array
    while IFS= read -r -d '' file; do
        matching_archives+=("$file")
    done < <(find "$sources_dir" -type f -name "$pattern" -print0)
done

# Disable nullglob after usage
shopt -u nullglob

# Remove any non-existent files from the array
existing_archives=()
for archive in "${matching_archives[@]}"; do
    if [[ -f "$archive" ]]; then
        existing_archives+=("$archive")
    fi
done

# Check that exactly one archive exists
if [[ ${#existing_archives[@]} -ne 1 ]]; then
    fatal "Exactly one archive for version '${version}' must exist in '${sources_dir}'. Found: ${#existing_archives[@]}" 1
fi

archive_file="${existing_archives[0]}"
echo "Found archive: ${archive_file}"

# Define the extraction folder (same name as version)
archive_folder="${sources_dir}/${version}"

# Function to uncompress the archive
uncompress_archive() {
    local archive="$1"
    local destination="$2"

    case "$archive" in
        *.zip)
            echo "Unzipping zip '${archive}' to '${destination}'..."
            mkdir -p "$destination" || fatal "Failed to create directory '${destination}'" 3
            if ! unzip -q "$archive" -d "$destination"; then
                rmdir "$destination" 2>/dev/null
                fatal "Failed to unzip '${archive}'" 4
            fi
            ;;
        *.tar.gz)
            echo "Extracting tar.gz '${archive}' to '${destination}'..."
            mkdir -p "$destination" || fatal "Failed to create directory '${destination}'" 3
            if ! tar -xzf "$archive" -C "$destination" --strip-components=1; then
                rmdir "$destination" 2>/dev/null
                fatal "Failed to extract '${archive}'" 41
            fi
            ;;
        *.tar.xz)
            echo "Extracting tar.xz '${archive}' to '${destination}'..."
            mkdir -p "$destination" || fatal "Failed to create directory '${destination}'" 3
            if ! tar -xJf "$archive" -C "$destination" --strip-components=1; then
                rmdir "$destination" 2>/dev/null
                fatal "Failed to extract '${archive}'" 41
            fi
            ;;
        *.tar)
            echo "Extracting tar '${archive}' to '${destination}'..."
            mkdir -p "$destination" || fatal "Failed to create directory '${destination}'" 3
            if ! tar -xf "$archive" -C "$destination" --strip-components=1; then
                rmdir "$destination" 2>/dev/null
                fatal "Failed to extract '${archive}'" 42
            fi
            ;;
        *)
            fatal "Unsupported archive format for '${archive}'" 5
            ;;
    esac
}

# Check if the extraction folder exists
if [[ ! -d "$archive_folder" ]]; then
    echo "Extraction folder '${archive_folder}' does not exist. Proceeding to extract..."

    # Uncompress the archive
    uncompress_archive "$archive_file" "$archive_folder"
else
    echo "Extraction folder '${archive_folder}' already exists. Skipping extraction."
fi

first_folder=$(find "$archive_folder" -type f \( -name 'config*' -o -name 'Makefile' -o -name 'meson.build' \) -printf '%h\n' | sort -u | head -n 1)
if [[ -z "$first_folder" ]]; then
    fatal "No folder with config found in '$archive_folder'" 6
fi
# shellcheck disable=SC2001
first_folder=$(echo "${first_folder}" | sed "s|^${sources_dir}/||")
rm -f "$sources_dir/current"
ln -nfs "$first_folder" "$sources_dir/current"

NOW="$(/usr/bin/date +%Y%m%d-%H%M%S)"
LOGIN="$(/usr/bin/id -un)"
mkdir -p "${logs}"

PATH_LOG="${logs}/${LOGIN}-$(basename "$0" .bash)-${NOW}.log"
REL_PATH_LOG="logs/${LOGIN}-$(basename "$0" .bash)-${NOW}.log"
rm -f "${prj}/log"
ln -nfs "${REL_PATH_LOG}" "${prj}/log"

info "Script Execution DIR '$prj'"
ok "Logging execution in '$PATH_LOG' (ln -nfs '${prj}/log')"

function displayLog() {
    res=$?
    if [[ ${res} != 0 ]]; then tail -15 "${prj}/log" >&3; fi
    /usr/bin/date >&3
}
trap displayLog EXIT

cd "${prj}" || fatal "unable to access '${prj}'" 111

# shellcheck source=/dev/null
source "${DIR}/../echos/echoslog"
exec 3>&2
exec 1> "$PATH_LOG"
exec 2>&1

set -o xtrace

# Before calling setOption, store the install script parameters globally:
install_args=("$@")

function setOption() {
    local varname="$1"
    shift
    # Set the option to false (1) by default
    printf -v "$varname" "1"

    local term arg
    # For each term to search for
    for term in "$@"; do
        # Check against each install argument
        for arg in "${install_args[@]}"; do
            case "$arg" in
                "$term" | "$term="* | "--$term" | "--$term="* | "-$term" | "-$term="* )
                    # Found a match: set the option to true (0) and exit
                    printf -v "$varname" "0"
                    return 0
                    ;;
            esac
        done
    done
    return 0
}

_reconfigure=0
_reclean=0

function reconfigure() {
    if (( _reconfigure == 0 )); then return 0; fi
    return 1
}

function reclean() {
    if (( _reclean == 0 )); then return 0; fi
    return 1
}

# main: Acts as the central execution point, orchestrating the overall setup process including dependency checks, installations, and environmental configurations, ensuring the script achieves its purpose of preparing the environment or updating software as required.
function main() {
    info "main: Start build at '${NOW}', parameters: $*"
    setenv "$@"
    # shellcheck disable=SC2154
    cd "${tool_src}" || fatal "Unable to access tool_src '${tool_src}'" 22
    pwd
    setOption _reconfigure "configure" "cfg" "rc" "reconfigure"
    setOption _reclean "clean" "cl"
    # TODO: check if CPLX_CONFIG_DONE is defined (e.g. 'configure: exit 0')
    # if not, search 'creating Makefile$' by default.

    get_property CPLX_CONFIG_DONE
    local CPLX_CONFIG_DONE_CMD
    if [[ -z  "${CPLX_CONFIG_DONE}" ]]; then
        fatal "CPLX_CONFIG_DONE is not defined: no way to know if configure completed successfully" 211
    fi
    if [[ "${CPLX_CONFIG_DONE}" == "default" ]]; then
        CPLX_CONFIG_DONE_CMD="grep \"creating Makefile\$\" \"${tool_src}/config.log\""
    else
        # Extract the last word as the file part
        file_part="${CPLX_CONFIG_DONE##* }"
        
        # Extract everything except the last word as the command part
        value_part="${CPLX_CONFIG_DONE% *}"
        CPLX_CONFIG_DONE_CMD="grep \"${value_part}\" \"${tool_src}/${file_part}\""
    fi

    task "Must evaluate CPLX_CONFIG_DONE_CMD '${CPLX_CONFIG_DONE_CMD}'"

    # Execute the command and capture its return code
    local config_result
    eval "${CPLX_CONFIG_DONE_CMD}"
    config_result=$?


    # Check if the command succeeded (return code 0) or failed (non-zero)
    if [[ ${config_result} -eq 0 ]]; then
        ok "Configuration has successfully finished"
    else
        warning "main: existing config.log has not finished yet, force reconfiguring in '$(pwd)'"
        _reconfigure=0
    fi
    info "main: reconfigure='${_reconfigure}'"
    if reconfigure; then
        warning "main: reconfigure is true, so force reclean"
        _reclean=0
    fi
    info "main: reclean='${_reclean}'"
    if [[ -e "${tool_src}/config.log" ]] && ! reconfigure; then
        ok "main: config.log present, do not reconfigure"
    else
        configure
        res_config=$?
        if [[ ${res_config} != 0 ]]; then
            error "main: configure failed with '${res_config}'"
            return "${res_config}"
        fi
    fi
    if reclean; then
        clean
        res_clean=$?
        if [[ ${res_clean} != 0 ]]; then
            error "main: clean failed with '${res_clean}'"
            return "${res_clean}"
        fi
    else
        info "reclean is false, so no clean performed before build"
    fi

    build
    res_build=$?
    if [[ ${res_build} != 0 ]]; then
        error "main: build failed with '${res_build}'"
        return "${res_build}"
    fi
    install
    res_install=$?
    if [[ ${res_install} != 0 ]]; then
        error "main: install failed with '${res_install}'"
        return "${res_install}"
    fi
    package
    res_package=$?
    if [[ ${res_package} != 0 ]]; then
        error "main: package failed with '${res_package}'"
        return "${res_package}"
    fi
    get_property CPLX_BIN
    if [[ -z "$CPLX_BIN" ]]; then
        error "No CPLX_BIN found in the properties file '${properties_file}'"
        return 126
    fi
    if [[ ! "${CPLX_BIN}" == "true" ]]; then
        deploy
        res_deploy=$?
        if [[ ${res_deploy} != 0 ]]; then
            error "main: deploy failed with '${res_deploy}'"
            return "${res_deploy}"
        fi
    fi
    return $?
}

# if one of the parameter is "--reconfigure", shift, and set reconfigure=true, then pass the rest to main
main "$@"
res=$?
# echo "res='${res}'" >&3
if [[ ${res} != 0 ]]; then
    exit "${res}"
fi
ok "All done"