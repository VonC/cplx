#!/bin/bash
# shellcheck disable=SC2139

unset BASH_ENV
export BASH_ENV

senvDIR="$( cd "$( dirname "$(readlink -f "${BASH_SOURCE[0]}")" )" && pwd )"
senvDIR="$(dirname "${senvDIR}")"
export senvDIR

if [[ ! -e "${senvDIR}/current/usr/bin/python3" ]]; then return; fi

export PERLLIB="${senvDIR}/root/share/perl5:${senvDIR}/root/lib64/perl5/vendor_perl"
export PATH="${senvDIR}/current/bin:${senvDIR}/current/libexec/git-core:${PATH}"

export LD_LIBRARY_PATH="${senvDIR}/root/usr/lib64:${senvDIR}/root/usr/lib:${senvDIR}/root/lib64:${senvDIR}/root/lib:${senvDIR}/current/usr/lib64:${senvDIR}/current/lib64:${senvDIR}/current/usr/lib:${senvDIR}/current/lib"


export CPLUS_INCLUDE_PATH=/home/vonc/cplx/tools/tool/root/usr/include/c++/8

if [[ ":${MANPATH}:" != *":${senvDIR}/current/share/man:"* ]]; then
    export MANPATH="${senvDIR}/current/share/man:${MANPATH}"
fi

alias man='BASH_ENV= "${senvDIR}/bin/manw.sh"'