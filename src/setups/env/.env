#!/bin/bash
# shellcheck disable=SC2139
unset BASH_ENV
export BASH_ENV
# shellcheck disable=SC2139
unalias rm 2>/dev/null
# shellcheck disable=SC1090 source=/dev/null
if [[ -e "${HOME}/.profile" ]]; then source "${HOME}/.profile" > /dev/null; fi
alias rm='rm -i'
alias ll='ls -alrth --color'
alias h=history

alias glab='git lg --all --branches'
alias gl='git lg -10'
alias gla='git lg --all'

env_HOME_DIR="$( cd "$( dirname "$(readlink -f "${BASH_SOURCE[0]}")" )" && pwd )"
export env_HOME_DIR
env_DIR="$( cd "$( dirname "$(readlink -f "${BASH_SOURCE[0]}")" )" && pwd )"
export env_DIR
HOME="${env_HOME_DIR}"
export HOME

# shellcheck disable=SC1091
source "${env_HOME_DIR}/echos/echos"
source "${env_HOME_DIR}/bin/get_service_name.sh"
source "${env_HOME_DIR}/bin/get_env_name.sh"
# shellcheck disable=SC1091
source "${env_HOME_DIR}/bin/properties.sh"
source "${env_HOME_DIR}/bin/packages_management.sh"
# shellcheck disable=SC1091
source "${env_HOME_DIR}/tools/install_functions.sh"

alias senv="source ${env_DIR}/.env"
alias senve="vi ${env_DIR}/.env"
alias senvr="source ${env_DIR}/.env"
alias senvi="source ${env_DIR}/tools/tool/install_functions.sh"
alias aliasr="source \"${env_HOME_DIR}\"/.env"
alias aliase="TERM=rxvt-unicode-256color vim \"${env_HOME_DIR}\"/.env"
alias alias='. alias'
alias fnm='find . -type f -name "*.so.[0-1]" -o -name "*.so" -o -name "*.a" 2>/dev/null | xargs nm -A -u 2>/dev/null | grep -i'

if [[ -d /usr/gnu ]]; then
    export PATH="%PATH%:/usr/gnu/bin"
    alias ll='/usr/gnu/bin/ls -alrth --color'
    alias ls='/usr/gnu/bin/ls --color'
    stty erase ^?
fi

function fd() { find . -name "$1*" 2>/dev/null; }
function fds() { find . -name "*${1}*" 2>/dev/null; }
function rgrep() { grep -nRHI "${1}" -- ** 2>/dev/null; }
function rigrep() { grep -nRHIi "${1}" -- ** 2>/dev/null; }
alias rg=rgrep
alias rgi=rigrep

properties_file="${env_HOME_DIR}/cplx.properties"
export properties_file

# Define the function to determine the service based on the current working directory
determine_service() {
    local services
    get_property services
    tools="${services}"
    service_name "${tools}"
}

# Export the function so it can be used in PS1
export determine_service

envn=$(env_name)
case "${envn}" in
'DEV')
    export PS1="\[\e[97;46m\][\$(determine_service)-DEV]\[\e[m\] \u@\h:\w\\$ "
;;
'QAL')
    export PS1="\[\e[97;42m\][\$(determine_service)-QAL]\[\e[m\] \u@\h:\w\\$ "
;;
'PPD')
    export PS1="\[\e[97;45m\][\$(determine_service)-PPR]\[\e[m\] \u@\h:\w\\$ "
;;
'PRD')
    export PS1="\[\e[97;41m\][\$(determine_service)-PRD]\[\e[m\] \u@\h:\w\\$ "
;;
*)
    export PS1="\[\e[97;43m\][\$(determine_service)-UNK]\[\e[m\] \u@\h:\w\\$ "
;;
esac

alias vi='TERM=rxvt-unicode-256color vim'

alias cdas="cd ${env_HOME_DIR}"
alias i='${env_DIR}/install'
alias ii='GCLEAN=1 ${env_DIR}/install'
alias cdg='cd "${env_DIR}"'
alias cdr='cd "${env_DIR}/tools/tool/root"'
alias cdt='cd "${env_DIR}/tools"'
alias cdt='cd "${env_DIR}/tools"'
alias cdtt='cd "${env_DIR}/tools/tool"'
alias cdttc='cd "${env_DIR}/tools/tool/current"'
alias cdc='cd "${env_DIR}/tools/tool/current"'
alias cdb='cd "${env_DIR}/bin"'
alias cdl='cd "${env_DIR}/tools/tool/logs"'
alias cdlt='cd "${env_DIR}/tools/logs"'
alias cdtl='cd "${env_DIR}/tools/logs"'
alias cdp='cd "${env_DIR}/tools/pkgs"'
alias cdtp='cd "${env_DIR}/tools/tool/pkgs"'
# shellcheck disable=SC2154
alias cds='d="$(readlink "${env_DIR}/tools/tool/sources/current" 2>/dev/null)"; cd "${env_DIR}/tools/tool/sources/${d}/"'
alias tc='tail -f ~/tools/tool/sources/current/config.log'
alias tlc='tail -f ~/tools/tool/sources/current/config.log'
alias tl='tail -f ~/tools/tool/log'
alias tli='tail -f ~/tools/tool/log'
alias gpn=get_package_name

ilogf() { grep -E "^\+\s*?(ok|info|warning|fatal)" "${env_HOME_DIR}"/log|sed -s "s/'\?'\\\\'//g"; }
alias ilog='ilogf'

alias pkg='${env_HOME_DIR}/bin/mktar'
alias mktar='${env_HOME_DIR}/bin/mktar'

if [ -z "${senv_DIR}" ]; then senv_DIR=""; fi
if [[ "${LD_LIBRARY_PATH}" != "${senv_DIR}/current/lib64" ]]; then
    export PATH="/usr/local/bin:/usr/bin:/usr/sbin:/mingw64/bin"
    if [[ -e "${env_DIR}/tools/tool/bin/setenv" ]]; then
        # shellcheck source=/dev/null
        source "${env_DIR}/tools/tool/bin/setenv"
    fi
fi

export tools="${HOME}/tools"
export tool="${tools}/tool"
tool_prefix="$(readlink -f "${tool}/current")"
export tool_prefix
export tool_src="${tool}/sources/current"
export root="${tool}/root"
export tools_pkgs="${tools}/pkgs"
export tool_pkgs="${tool}/pkgs"
if [[ -e "${tool}/root" ]]; then
    tool_name="$(basename "$(readlink -f "${tool}")")"
    export tool_name
fi

get_property services
if [[ -z "${services}" ]]; then
    fatal "No services defined (list of tools to compile) in properties_file '${properties_file}'" 21
fi

get_property CPLX_ARCH_EXT
if [[ -z "${CPLX_ARCH_EXT}" ]]; then
    fatal "No CPLX_ARCH_EXT defined (should be el8.x86_64 or el7.x86_64, for instance) for '${tool_name}' in properties_file '${properties_file}'" 18
fi
get_property CPLX_CHECK_PREFIX
if [[ -z "${CPLX_ARCH_EXT}" ]]; then
    fatal "No CPLX_CHECK_PREFIX defined (element in installation directory) for '${tool_name}' in properties_file '${properties_file}'" 19
fi
get_property CPLX_CHECK_SRC
if [[ -z "${CPLX_CHECK_SRC}" ]]; then
    fatal "No CPLX_CHECK_SRC defined (element in source directory) for '${tool_name}' in properties_file '${properties_file}'" 20
fi
if [[ ! "$(basename "${CPLX_CHECK_PREFIX}")" == "$(basename "${CPLX_CHECK_SRC}")" ]]; then
    fatal "CPLX_CHECK_PREFIX '${CPLX_CHECK_PREFIX}' and CPLX_CHECK_SRC '${CPLX_CHECK_SRC}' should reference the same file for '${tool_name}' in properties_file '${properties_file}'" 59
fi
if ! get_property CPLX_BIN; then
    CPLX_BIN=""
fi
export CPLX_BIN

if [[ ":$PATH:" != *":${env_DIR}/tools/tool/bin:"* ]]; then
    export PATH="${env_DIR}/tools/tool/bin:${PATH}"
fi

if [[ ":$PATH:" != *":${env_DIR}/bin:"* ]]; then
    export PATH="${env_DIR}/bin:${PATH}"
fi

if [[ ":$PATH:" != *":${root}/usr/bin:"* ]]; then
    export PATH="${root}/usr/bin:${PATH}"
fi

export LS_COLORS='di=34;46:ln=95:so=32:pi=33:ex=31:bd=36;40:cd=34;43:su=30;41:sg=30;46:tw=30;42:ow=30;43'