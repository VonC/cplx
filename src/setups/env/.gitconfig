[alias]
        st = status
        lg2 = log --graph --format=format:'%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(reset) %C(bold green)(%ar)%C(reset)%C(bold yellow)%d%C(reset)%n''          %C(white)%s%C(reset) %C(bold white)- %an%C(re
set)' --abbrev-commit
        lg = !"git lg2"
        br = branch
[core]
        autocrlf = false
        commitGraph = true
        longpaths = true
        quotepath = false
        safecrlf = false
[gc]
        writeCommitGraph = true
[init]
        templateDir = ~/git/share/git-core/templates
[protocol]
        version = 2
[pull]
        rebase = true
[push]
        default = simple
[rebase]
        autostash = true
[user]
        useConfigOnly = true
[credential]
        helper = cache --timeout=36000