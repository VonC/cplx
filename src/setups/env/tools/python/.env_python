#!/bin/bash
# shellcheck disable=SC2142

env_PYTHON_DIR="$( cd "$( dirname "$(readlink -f "${BASH_SOURCE[0]}")" )" && pwd )"
export env_PYTHON_DIR
PYTHON_DIR_BIN="${env_PYTHON_DIR}/bin"
export PYTHON_DIR_BIN

PYTHON_DIR_ROOT="${env_PYTHON_DIR}/root"
export PYTHON_DIR_ROOT

env_PYTHON_FILE="${env_PYTHON_DIR}/.env_python"
export env_PYTHON_FILE

alias p_senv='source "${env_PYTHON_FILE}"'
alias p_senve='vi "${env_PYTHON_FILE}"'
alias p_senvr='source "${env_PYTHON_FILE}"'
alias p_aliasr='source "${env_PYTHON_FILE}"'
alias p_aliase='TERM=rxvt-unicode-256color vim "${env_PYTHON_FILE}"'

unalias man 2>/dev/null
unalias p_man 2>/dev/null
alias git='BASH_ENV= gitshellenv=$- "${PYTHON_DIR_BIN}/gitw.sh"'

# cSpell: disable
alias cdpb='cd "${PYTHON_DIR_BIN}"'
alias cdp='cd "${env_PYTHON_DIR}"'
alias cdpr='cd "${env_PYTHON_DIR}/root"'
alias cdpcb='cd "${env_PYTHON_DIR}/current/bin"'
alias cdpc='cd "${env_PYTHON_DIR}/current/"'
alias cdpl='cd "${env_PYTHON_DIR}/logs"'
alias cdpp='cd "${env_PYTHON_DIR}/pkgs"'
# cSpell: enable

if [[ ":$PATH:" != *":${env_PYTHON_DIR}/bin:"* ]]; then
    export PATH="${env_PYTHON_DIR}/bin:${PATH}"
fi

export PYTHON_EXEC_PATH="${env_PYTHON_DIR}/current/libexec/git-core"

if [[ ! -e "${env_PYTHON_DIR}/current/share/man/man1/python.1" ]]; then
  ln -nfs "$(readlink "${DIR}/current/share/man/man1/python3.1")" "${DIR}/current/share/man/man1/python.1"
fi

if [[ ":$MANPATH:" != *":${env_PYTHON_DIR}/current/share/man:"* ]]; then
    export MANPATH="${env_PYTHON_DIR}/current/share/man:${MANPATH}"
fi
