#!/bin/bash

alias glab='git lg --all --branches'
alias gl='git lg -10'
alias gla='git lg --all'

env_GIT_DIR="$( cd "$( dirname "$(readlink -f "${BASH_SOURCE[0]}")" )" && pwd )"
export env_GIT_DIR
GIT_DIR_BIN="${env_GIT_DIR}/bin"
export GIT_DIR_BIN
GIT_DIR_ROOT="${env_GIT_DIR}/root"
export GIT_DIR_ROOT

env_GIT_FILE="${env_GIT_DIR}/.env_git"
export env_GIT_FILE

alias g_senv='source "${env_GIT_FILE}"'
alias g_senve='vi "${env_GIT_FILE}"'
alias g_senvr='source "${env_GIT_FILE}"'
alias g_aliasr='source "${env_GIT_FILE}"'
alias g_aliase='TERM=rxvt-unicode-256color vim "${env_GIT_FILE}"'

unalias man 2>/dev/null
unalias g_man 2>/dev/null
alias git='BASH_ENV= gitshellenv=$- "${GIT_DIR_BIN}/gitw.sh"'

# cSpell: disable
alias cdgb='cd "${GIT_DIR_BIN}"'
alias cdg='cd "${env_GIT_DIR}"'
alias cdgr='cd "${env_GIT_DIR}/root"'
alias cdgcb='cd "${env_GIT_DIR}/current/bin"'
alias cdgc='cd "${env_GIT_DIR}/current/"'
alias cdgl='cd "${env_GIT_DIR}/logs"'
alias cdgp='cd "${env_GIT_DIR}/pkgs"'
# cSpell: enable

if [[ ":$PATH:" != *":${env_GIT_DIR}/bin:"* ]]; then
    export PATH="${env_GIT_DIR}/bin:${PATH}"
fi

if [[ ! -e "${HOME}/.gitconfig" ]]; then
    cp "${env_GIT_DIR}/.gitconfig" "${HOME}/.gitconfig"
fi

if [[ ":$PERLLIB:" != *":${env_GIT_DIR}/current/share/perl5:"* ]]; then
    export PERLLIB="${env_GIT_DIR}/current/share/perl5:${PERLLIB}"
fi

if [[ ":$LD_LIBRARY_PATH:" != *":${GIT_DIR_ROOT}/usr/lib64:${GIT_DIR_ROOT}/usr/lib:${GIT_DIR_ROOT}/lib64:${GIT_DIR_ROOT}/lib:"* ]]; then
    export LD_LIBRARY_PATH="${GIT_DIR_ROOT}/usr/lib64:${GIT_DIR_ROOT}/usr/lib:${GIT_DIR_ROOT}/lib64:${GIT_DIR_ROOT}/lib:${LD_LIBRARY_PATH}"
fi

export GIT_EXEC_PATH="${env_GIT_DIR}/current/libexec/git-core"

if [[ ":$MANPATH:" != *":${env_GIT_DIR}/current/share/man:"* ]]; then
    export MANPATH="${env_GIT_DIR}/current/share/man:${MANPATH}"
fi
