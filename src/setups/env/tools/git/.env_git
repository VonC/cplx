#!/bin/bash
# shellcheck disable=SC2142

alias glab='git lg --all --branches'
alias gl='git lg -10'
alias gla='git lg --all'
alias gs='git st'
alias gc='git commit'
alias gce='git commit --allow-empty -m'
alias gcae='_gcae_func() { git commit --amend --allow-empty -m "$*"; }; _gcae_func'
alias gcm='_gcm_func() { git commit -m "$*"; }; _gcm_func'
alias gcam='git commit --amend --no-edit'
alias gcma='_gcma_func() { git commit --amend -m "$*"; }; _gcma_func'
alias gcamm='_gcma_func() { git commit --amend -m "$*"; }; _gcma_func'
alias gd='git diff --color-words=.'
alias gdc='git diff --cached --color-words=.'
alias gca='git commit --amend'
alias gpf='git add .; git commit --allow-empty --amend --no-edit; git push --force'
alias gdni='git diff --no-index --color-words=.'
alias gcie='git commit --allow-empty -m "Initial empty commit"'
alias ggy='_ggy_func() { git grep --color=always -n "$1" -- *.yml; }; _ggy_func'
alias gp='git push'
alias gpft='git push --follow-tags'
alias gpft2='git push --follow-tags origin2'
alias gpft2m='git push --follow-tags origin2 main'
alias gcunone='git config user.name "none"; git config user.email none@none.com'
alias ggo='_ggo_func() { git grep --color=always -n "$1" -- *.go | grep -v vendor; }; _ggo_func'
alias ggoi='_ggoi_func() { git grep --color=always -ni "$1" -- *.go | grep -v vendor; }; _ggoi_func'
alias ggyi='_ggyi_func() { git grep --color=always -ni "$1" -- *.yml; }; _ggyi_func'
alias gtn='git tag -l --format="%(contents)"'
alias gtm='git tag -l --format="%(contents)"'
alias gbca='_gb_func() { git bundle create $1.bundle --all; }; _gb_func'

env_GIT_DIR="$( cd "$( dirname "$(readlink -f "${BASH_SOURCE[0]}")" )" && pwd )"
export env_GIT_DIR
GIT_DIR_BIN="${env_GIT_DIR}/bin"
export GIT_DIR_BIN

GIT_DIR_ROOT="${env_GIT_DIR}/root"
export GIT_DIR_ROOT

env_GIT_FILE="${env_GIT_DIR}/.env_git"
export env_GIT_FILE

alias g_senv='source "${env_GIT_FILE}"'
alias g_senve='vi "${env_GIT_FILE}"'
alias g_senvr='source "${env_GIT_FILE}"'
alias g_aliasr='source "${env_GIT_FILE}"'
alias g_aliase='TERM=rxvt-unicode-256color vim "${env_GIT_FILE}"'

unalias man 2>/dev/null
unalias g_man 2>/dev/null
alias git='BASH_ENV= gitshellenv=$- "${GIT_DIR_BIN}/gitw.sh"'

# cSpell: disable
alias cdgb='cd "${GIT_DIR_BIN}"'
alias cdg='cd "${env_GIT_DIR}"'
alias cdgr='cd "${env_GIT_DIR}/root"'
alias cdgcb='cd "${env_GIT_DIR}/current/bin"'
alias cdgc='cd "${env_GIT_DIR}/current/"'
alias cdgl='cd "${env_GIT_DIR}/logs"'
alias cdgp='cd "${env_GIT_DIR}/pkgs"'
# cSpell: enable

if [[ ":$PATH:" != *":${env_GIT_DIR}/bin:"* ]]; then
    export PATH="${env_GIT_DIR}/bin:${PATH}"
fi

if [[ ! -e "${HOME}/.gitconfig" ]]; then
    cp "${env_GIT_DIR}/.gitconfig" "${HOME}/.gitconfig"
fi

export GIT_EXEC_PATH="${env_GIT_DIR}/current/libexec/git-core"

if [[ ":$MANPATH:" != *":${env_GIT_DIR}/current/share/man:"* ]]; then
    export MANPATH="${env_GIT_DIR}/current/share/man:${MANPATH}"
fi
