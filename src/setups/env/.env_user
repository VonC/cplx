#!/bin/bash

# shellcheck disable=SC2139
unalias rm 2>/dev/null
# shellcheck disable=SC1090 source=/dev/null
if [[ -e "${HOME}/.profile" ]]; then source "${HOME}/.profile" > /dev/null 2>&1; fi
alias rm='rm -i'
alias ll='ls -alrth --color'
alias h=history

unset BASH_ENV
export BASH_ENV

tools_DIR="$( cd "$( dirname "$(readlink -f "${BASH_SOURCE[0]}")" )" && pwd )"
export tools_DIR

GNUPGHOME="${tools_DIR}/certs"
export GNUPGHOME
GPG_TTY=$(tty)
export GPG_TTY
chmod 700 "${GNUPGHOME}"

# shellcheck disable=SC1091
source "${tools_DIR}/echos/echos"

env_FILE="${HOME}/.env"
if [[ -e "${HOME}/.env_init" ]]; then env_FILE="${HOME}/.env_init"; fi
if [[ -e "${HOME}/.env_" ]]; then env_FILE="${HOME}/.env_"; fi

alias senv="source \"${env_FILE}\""
alias senve="vi \"${env_FILE}\""
alias senvr="source \"${env_FILE}\""
alias aliasr="source \"${env_FILE}\""
alias aliase="TERM=rxvt-unicode-256color vim \"${env_FILE}\""
alias alias='. alias'
alias fnm='find . -type f -name "*.so.[0-9]" -o -name "*.so" -o -name "*.a" -o -name "*.o" 2>/dev/null | xargs nm -A 2>/dev/null | grep -i'

if [[ -d /usr/gnu ]]; then
    export PATH="%PATH%:/usr/gnu/bin"
    alias ll='/usr/gnu/bin/ls -alrth --color'
    alias ls='/usr/gnu/bin/ls --color'
    stty erase ^?
fi

function find_name_start() { find . -name "$1*" 2>/dev/null; }
function find_name_star() { find . -name "*${1}*" 2>/dev/null; }
function rgrep() { grep -nRHI "${1}" -- ** 2>/dev/null; }
function rigrep() { grep -nRHIi "${1}" -- ** 2>/dev/null; }

alias fd=find_name_start
alias fds=find_name_star
alias rg=rgrep
alias rgi=rigrep
alias rgp=rgrep_packages
alias rgip=rigrep_packages
alias rgpi=rigrep_packages
alias man=manw

function_missing=0
if ! declare -F service_name >/dev/null; then
    error "'{HOME}/.env_init' MUST define and export the service_name() function"
    function_missing=1
fi
if ! declare -F env_name >/dev/null; then
    error "'{HOME}/.env_init' MUST define and export the env_name() function"
    function_missing=1
fi
if [[ ${function_missing} != 0 ]]; then fatal "Function missing in '{HOME}/.env_init'" 11; fi

envn=$(env_name)
case "${envn}" in
'DEV')
    export PS1="\[\e[97;46m\][\$(service_name)-DEV]\[\e[m\] \u@\h:\w\\$ "
;;
'QAL')
    export PS1="\[\e[97;42m\][\$(service_name)-QAL]\[\e[m\] \u@\h:\w\\$ "
;;
'PPD')
    export PS1="\[\e[97;45m\][\$(service_name)-PPR]\[\e[m\] \u@\h:\w\\$ "
;;
'PRD')
    export PS1="\[\e[97;41m\][\$(service_name)-PRD]\[\e[m\] \u@\h:\w\\$ "
;;
*)
    export PS1="\[\e[97;43m\][\$(service_name)-UNK]\[\e[m\] \u@\h:\w\\$ "
;;
esac

alias vi='TERM=rxvt-unicode-256color vim'

alias cdb='cd "${HOME}/bin"'
alias cdt='cd "${tools_DIR}"'
alias cdtb='cd "${tools_DIR}/bin"'

export PATH="/usr/local/bin:/usr/bin:/usr/sbin:/mingw64/bin"

if [[ ":$PATH:" != *":${tools_DIR}/bin:"* ]]; then
    export PATH="${tools_DIR}/bin:${PATH}"
fi
if [[ ":$PATH:" != *":${tools_DIR}/certs:"* ]]; then
    export PATH="${tools_DIR}/certs:${PATH}"
fi
if [[ ":$PATH:" != *":${HOME}/bin:"* ]]; then
    export PATH="${HOME}/bin:${PATH}"
fi

if [[ -e "${HOME}/cplx" ]]; then
    alias rs='${HOME}/cplx/bin/rsync.sh'
    alias rsn='${HOME}/cplx/bin/rsync.sh -n'
    alias rse='vi "${HOME}/cplx/rsync_include.txt"'
    alias rsee='vi "${HOME}/cplx/rsync_exclude.txt"'
fi

export LS_COLORS='di=34;46:ln=95:so=32:pi=33:ex=31:bd=36;40:cd=34;43:su=30;41:sg=30;46:tw=30;42:ow=30;43'

# shellcheck disable=SC1091
source "${tools_DIR}/git/.env_git"
